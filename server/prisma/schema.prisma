generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                 @id @default(autoincrement())
  username            String              @unique
  password            String
  role                String
  fullName            String?
  email               String?             @unique
  phoneNumber         String?
  department          String?
  designation         String?
  lastPasswordChange  DateTime?           @default(now())
  isDisabled          Boolean             @default(false)
  forcePasswordChange Boolean             @default(false)
  lastLogin           DateTime?
  createdAt           DateTime            @default(now())
  activityPerformed   ActivityLog[]       @relation("PerformedBy")
  announcements       Announcement[]      @relation("PostedBy")
  externalStaffTasks  ExternalMarkAssignment[] @relation("ExternalStaffAssignments")
  facultyAbsences     FacultyAbsence[]
  marksApproved       Marks[]             @relation("MarksApprover")
  materials           Material[]          @relation("Instructor")
  takenAttendance     StudentAttendance[]
  substitutions       Substitution[]
  timetables          Timetable[]
  externalMarksSubmitted ExternalMark[] @relation("ExternalEvaluator")
  examSessions        ExamSession[]   @relation("CreatedSessions")
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  action      String
  description String
  performedBy Int
  targetId    Int?
  timestamp   DateTime @default(now())
  performer   User     @relation("PerformedBy", fields: [performedBy], references: [id])
}

model Department {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  code      String?  @unique
  hodId     Int?
  sections  String   @default("A,B,C")
  years     String   @default("2,3,4")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id             Int                 @id @default(autoincrement())
  registerNumber String              @unique
  name           String
  department     String?
  year           Int
  section        String
  semester       Int
  createdAt      DateTime            @default(now())
  arrears        Arrear[]
  marks          Marks[]
  results        SemesterResult[]
  attendance     StudentAttendance[]
  dummyMappings  SubjectDummyMapping[]
  hallAllocations HallAllocation[]
}

model Timetable {
  id            Int            @id @default(autoincrement())
  department    String?
  year          Int
  semester      Int
  section       String
  day           String
  period        Int
  duration      Int            @default(1)
  type          String?
  subjectName   String?
  facultyName   String?
  room          String?
  subjectId     Int?
  facultyId     Int?
  updatedAt     DateTime       @updatedAt
  substitutions Substitution[]
  faculty       User?          @relation(fields: [facultyId], references: [id])
  subject       Subject?       @relation(fields: [subjectId], references: [id])

  @@unique([department, year, semester, section, day, period])
}

model Subject {
  id                 Int                 @id @default(autoincrement())
  code               String              @unique
  name               String
  shortName          String?
  department         String?
  semester           Int
  credits            Int                 @default(3)
  type               String              @default("DEPARTMENT")
  arrears            Arrear[]
  externalStaffTasks ExternalMarkAssignment[]
  facultyAssignments FacultyAssignment[]
  marks              Marks[]
  materials          Material[]
  attendance         StudentAttendance[]
  timetables         Timetable[]
  dummyMappings      SubjectDummyMapping[]
  externalMarks     ExternalMark[]
  examSessionLinks  ExamSessionSubjects[]
  hallAllocations   HallAllocation[]
}

model Announcement {
  id         Int      @id @default(autoincrement())
  title      String
  content    String
  category   String   @default("GENERAL")
  department String?
  year       Int?
  semester   Int?
  section    String?
  postedBy   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation("PostedBy", fields: [postedBy], references: [id])
}

model Material {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  fileUrl      String?
  subjectId    Int
  instructorId Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  instructor   User     @relation("Instructor", fields: [instructorId], references: [id])
  subject      Subject  @relation(fields: [subjectId], references: [id])
}

model FacultyAssignment {
  id        Int     @id @default(autoincrement())
  facultyId Int
  subjectId Int
  section   String
  subject   Subject @relation(fields: [subjectId], references: [id])
}

model Marks {
  id              Int          @id @default(autoincrement())
  studentId       Int
  subjectId       Int
  cia1_test       Float?
  cia1_assignment Float?
  cia1_attendance Float?
  cia2_test       Float?
  cia2_assignment Float?
  cia2_attendance Float?
  cia3_test       Float?
  cia3_assignment Float?
  cia3_attendance Float?
  internal        Float?
  isLocked        Boolean      @default(false)
  isApproved      Boolean      @default(false)
  isLocked_cia1   Boolean      @default(false)
  isLocked_cia2   Boolean      @default(false)
  isLocked_cia3   Boolean      @default(false)
  isApproved_cia1 Boolean      @default(false)
  isApproved_cia2 Boolean      @default(false)
  isApproved_cia3 Boolean      @default(false)
  approvedBy      Int?
  approvedAt      DateTime?
  updatedAt       DateTime     @updatedAt
  endSemMarks     EndSemMarks?
  approver        User?        @relation("MarksApprover", fields: [approvedBy], references: [id])
  subject         Subject      @relation(fields: [subjectId], references: [id])
  student         Student      @relation(fields: [studentId], references: [id])

  @@unique([studentId, subjectId])
  @@index([studentId])
  @@index([subjectId])
}

model EndSemMarks {
  id            Int      @id @default(autoincrement())
  marksId       Int      @unique
  externalMarks Float?
  totalMarks    Float?
  grade         String?
  resultStatus  String?
  isPublished   Boolean  @default(false)
  isLocked      Boolean  @default(false)
  attendanceSnapshot Float?
  updatedAt          DateTime @updatedAt
  marks              Marks    @relation(fields: [marksId], references: [id])

  @@index([marksId])
}

model GradeSettings {
  id            Int      @id @default(autoincrement())
  regulation    String
  grade         String
  minPercentage Float
  maxPercentage Float
  gradePoint    Int
  resultStatus  String   @default("PASS")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([regulation, grade])
}

model SemesterControl {
  id            Int      @id @default(autoincrement())
  department    String
  year          Int
  semester      Int
  section       String
  markEntryOpen Boolean  @default(false)
  isPublished   Boolean  @default(false)
  isLocked      Boolean  @default(false)
  isFrozen      Boolean  @default(false)
  actionLogs    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([department, year, semester, section])
}

model SemesterResult {
  id            Int      @id @default(autoincrement())
  studentId     Int
  semester      Int
  gpa           Float
  cgpa          Float
  totalCredits  Int
  earnedCredits Int
  resultStatus  String
  isLocked      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  student       Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, semester])
}

model Arrear {
  id           Int             @id @default(autoincrement())
  studentId    Int
  subjectId    Int
  semester     Int
  attemptCount Int             @default(1)
  isCleared    Boolean         @default(false)
  clearedInSem Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  subject      Subject         @relation(fields: [subjectId], references: [id])
  student      Student         @relation(fields: [studentId], references: [id])
  attempts     ArrearAttempt[]

  @@unique([studentId, subjectId])
}

model ArrearAttempt {
  id            Int       @id @default(autoincrement())
  arrearId      Int
  semester      Int
  internalMarks Float?
  externalMarks Float?
  totalMarks    Float?
  grade         String?
  resultStatus  String?
  examDate      DateTime?
  createdAt     DateTime  @default(now())
  arrear        Arrear    @relation(fields: [arrearId], references: [id])
}

model ExternalMarkAssignment {
  id               Int      @id @default(autoincrement())
  staffId          Int
  subjectId        Int
  deadline         DateTime
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  subject          Subject  @relation(fields: [subjectId], references: [id])
  staff            User     @relation("ExternalStaffAssignments", fields: [staffId], references: [id])
}

model FacultyAbsence {
  id        Int      @id @default(autoincrement())
  facultyId Int
  date      String
  period    Int      @default(0)
  reason    String?
  createdAt DateTime @default(now())
  faculty   User     @relation(fields: [facultyId], references: [id])

  @@unique([facultyId, date, period])
}

model Substitution {
  id                  Int       @id @default(autoincrement())
  timetableId         Int
  substituteFacultyId Int
  date                String
  createdAt           DateTime  @default(now())
  substituteFaculty   User      @relation(fields: [substituteFacultyId], references: [id])
  timetable           Timetable @relation(fields: [timetableId], references: [id])

  @@unique([timetableId, date])
}

model StudentAttendance {
  id        Int      @id @default(autoincrement())
  studentId Int
  subjectId Int
  facultyId Int
  date      String
  period    Int      @default(0)
  status    String
  createdAt DateTime @default(now())
  faculty   User     @relation(fields: [facultyId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])

  @@unique([studentId, subjectId, date, period])
}

model SubjectDummyMapping {
  id                 Int      @id @default(autoincrement())
  studentId          Int
  originalRegisterNo String
  subjectId          Int
  subjectCode        String
  department         String
  semester           Int
  section            String
  academicYear       String
  dummyNumber        String   @unique
  mappingLocked      Boolean  @default(false)
  createdAt          DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([studentId, subjectId])
  @@unique([subjectId, dummyNumber])
  @@index([dummyNumber])
  @@index([studentId])
  @@index([subjectId])
}

model ExternalMark {
  id                  Int      @id @default(autoincrement())
  subjectId           Int
  dummyNumber         String   @unique
  rawExternal100      Float
  convertedExternal60 Float
  submittedBy         Int
  submittedAt         DateTime @default(now())
  locked              Boolean  @default(false)

  subject   Subject @relation(fields: [subjectId], references: [id])
  evaluator User    @relation("ExternalEvaluator", fields: [submittedBy], references: [id])

  @@index([dummyNumber])
  @@index([subjectId])
}

model ExamSession {
  id          Int      @id @default(autoincrement())
  examName    String
  examDate    DateTime
  session     String   // "FN" or "AN"
  isLocked    Boolean  @default(false)
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User     @relation("CreatedSessions", fields: [createdBy], references: [id])
  subjects    ExamSessionSubjects[]
  allocations HallAllocation[]
}

model ExamSessionSubjects {
  id            Int      @id @default(autoincrement())
  examSessionId Int
  subjectId     Int

  examSession   ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  subject       Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examSessionId, subjectId])
}

model Hall {
  id             Int      @id @default(autoincrement())
  hallName       String
  blockName      String
  totalRows      Int
  benchesPerRow  Int
  capacity       Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  allocations    HallAllocation[]
}

model HallAllocation {
  id               Int      @id @default(autoincrement())
  examSessionId    Int
  hallId           Int
  studentId        Int
  subjectId        Int
  department       String
  year             Int
  seatNumber       String
  rowNumber        Int
  columnNumber     Int
  createdAt        DateTime @default(now())

  examSession      ExamSession @relation(fields: [examSessionId], references: [id], onDelete: Cascade)
  hall             Hall        @relation(fields: [hallId], references: [id], onDelete: Cascade)
  student          Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject          Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examSessionId, studentId])
  @@unique([examSessionId, hallId, seatNumber])
}
